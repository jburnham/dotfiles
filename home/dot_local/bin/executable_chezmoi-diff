#!/usr/bin/env bash
set -euo pipefail

# chezmoi diff.command wrapper: normalizes JSON (sort keys) for settings.json
# before diffing, so key-order churn from the destination file doesn't appear
# as a diff.

norm() {
  local f=$1
  case "$f" in
    *.claude/settings.json | *.claude/settings.local.json)
      if command -v jq >/dev/null 2>&1 && jq --sort-keys . "$f" 2>/dev/null; then
        return
      fi
      cat -- "$f"
      ;;
    *)
      cat -- "$f"
      ;;
  esac
}

tmp_a=$(mktemp)
tmp_b=$(mktemp)
trap 'rm -f "$tmp_a" "$tmp_b"' EXIT

norm "$1" >"$tmp_a"
norm "$2" >"$tmp_b"

# Use ~ literal in the label so copy-pasted paths work as-is in shells.
# shellcheck disable=SC2088
label="~/${1#"$HOME"/}"
diff -u -L "$label" -L "$label" "$tmp_a" "$tmp_b"
