#!/usr/bin/env bash
# sb — Run any command inside a macOS sandbox-exec jail
#
# Usage: sb [options] <command> [args...]
#   -c, --clean-env   Sanitize environment (strip secrets, pass only essentials)
#
# Examples:
#   sb npm install          # sandbox with full env passthrough
#   sb -c claude            # sandbox with sanitized env
#   sb --clean-env bash     # sandbox with sanitized env
#
# Policy (defined in my.sb):
#   - Writes allowed: project dir, ~/.claude/, tmpdir, dev tools caches
#     (~/go/pkg/mod, ~/.cargo/{registry,git}, ~/.npm, ~/.cache, ~/Library/Caches)
#   - Reads blocked: private keys, auth tokens, browser profiles, password
#     managers, personal folders (Documents, Downloads, Pictures, Movies, Music)
#   - Network, exec, IPC: all allowed
#
# Safety: refuses to run from $HOME (would allowlist writes to entire home dir)

set -euo pipefail

CLEAN_ENV=false

# Parse sb-specific flags (before the command)
while [[ $# -gt 0 ]]; do
  case "$1" in
    -c | --clean-env)
      CLEAN_ENV=true
      shift
      ;;
    -h | --help)
      echo "Usage: sb [options] <command> [args...]"
      echo "Options:"
      echo "  -c, --clean-env   Sanitize environment (strip secrets)"
      exit 0
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      exit 1
      ;;
    *) break ;;
  esac
done

# Find the profile in the home directory
PROFILE="${HOME}/my.sb"

if [[ ! -f $PROFILE ]]; then
  echo "error: sandbox profile not found: ${PROFILE}" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  echo "Usage: sb [options] <command> [args...]" >&2
  echo "Example: sb bash" >&2
  echo "Example: sb -c claude" >&2
  exit 1
fi

# Resolve real paths
RESOLVED_HOME="$(cd "$HOME" && pwd -P)"
PROJECT_DIR="$(pwd -P)"

# Walk up to git root if inside a repo (so the full project is writable)
GIT_ROOT="$(git -C "$PROJECT_DIR" rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -n $GIT_ROOT ]]; then
  PROJECT_DIR="$(cd "$GIT_ROOT" && pwd -P)"
fi

# Safety guard: refuse to run from $HOME directly
if [[ $PROJECT_DIR == "$RESOLVED_HOME" ]]; then
  echo "error: refusing to run from \$HOME ($RESOLVED_HOME)" >&2
  echo "" >&2
  # $HOME is intentionally literal here
  # shellcheck disable=SC2016
  echo 'Running from $HOME would grant write access to your entire' >&2
  echo "home directory, defeating the purpose of the sandbox." >&2
  echo "" >&2
  echo "Instead, cd into a project directory first:" >&2
  echo "  cd ~/my-project && sb <command>" >&2
  exit 1
fi

# Resolve TMPDIR (macOS sets this to a per-user path like /var/folders/xx/...)
RESOLVED_TMPDIR="$(cd "${TMPDIR:-/tmp}" && pwd -P)"

# Resolve XDG base dirs (fall back to spec defaults when unset).
# Resolve symlinks when the dir exists so sandbox rules match realpath.
resolve_dir() {
  if [[ -d $1 ]]; then
    (cd "$1" && pwd -P)
  else
    echo "$1"
  fi
}
XDG_CONFIG="$(resolve_dir "${XDG_CONFIG_HOME:-${RESOLVED_HOME}/.config}")"
XDG_DATA="$(resolve_dir "${XDG_DATA_HOME:-${RESOLVED_HOME}/.local/share}")"
XDG_CACHE="$(resolve_dir "${XDG_CACHE_HOME:-${RESOLVED_HOME}/.cache}")"
XDG_STATE="$(resolve_dir "${XDG_STATE_HOME:-${RESOLVED_HOME}/.local/state}")"

SANDBOX_ARGS=(
  sandbox-exec -f "$PROFILE"
  -D "_HOME=${RESOLVED_HOME}"
  -D "_PROJECT_DIR=${PROJECT_DIR}"
  -D "_TMPDIR=${RESOLVED_TMPDIR}"
  -D "_XDG_CONFIG_HOME=${XDG_CONFIG}"
  -D "_XDG_DATA_HOME=${XDG_DATA}"
  -D "_XDG_CACHE_HOME=${XDG_CACHE}"
  -D "_XDG_STATE_HOME=${XDG_STATE}"
)

if [[ $CLEAN_ENV == true ]]; then
  # Build sanitized environment: only essentials, no secrets
  ENV_ARGS=(
    /usr/bin/env -i
    "HOME=${RESOLVED_HOME}"
    "USER=${USER:-}"
    "SHELL=${SHELL:-/bin/zsh}"
    "TERM=${TERM:-xterm-256color}"
    "LANG=${LANG:-en_US.UTF-8}"
    "PATH=${PATH}"
    "TMPDIR=${RESOLVED_TMPDIR}"
  )
  # Passthrough SSH agent socket (for git-over-SSH; not keys, just the socket)
  [[ -n ${SSH_AUTH_SOCK:-} ]] && ENV_ARGS+=("SSH_AUTH_SOCK=${SSH_AUTH_SOCK}")
  # Passthrough editor preferences
  [[ -n ${EDITOR:-} ]] && ENV_ARGS+=("EDITOR=${EDITOR}")
  [[ -n ${VISUAL:-} ]] && ENV_ARGS+=("VISUAL=${VISUAL}")
  # Passthrough XDG dirs (resolved above so the profile and the env agree)
  ENV_ARGS+=(
    "XDG_CONFIG_HOME=${XDG_CONFIG}"
    "XDG_DATA_HOME=${XDG_DATA}"
    "XDG_CACHE_HOME=${XDG_CACHE}"
    "XDG_STATE_HOME=${XDG_STATE}"
  )
  [[ -n ${XDG_RUNTIME_DIR:-} ]] && ENV_ARGS+=("XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR}")
  # Passthrough *_BASE_URL vars (for future proxy support)
  # env(1) failing is not a realistic concern
  # shellcheck disable=SC2312
  while IFS='=' read -r key val; do
    [[ $key == *_BASE_URL ]] && ENV_ARGS+=("${key}=${val}")
  done < <(env)

  exec "${SANDBOX_ARGS[@]}" "${ENV_ARGS[@]}" "$@"
else
  exec "${SANDBOX_ARGS[@]}" "$@"
fi
