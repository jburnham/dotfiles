SSOConfig:
    Work:
        AuthUrlAction: open
        SSORegion: us-east-1
        StartUrl: {{ .aws_sso_start_url }}
        Accounts:
          {{ .aws_sso_account_id }}:
            Name: prod
ConsoleDuration: 720
CacheRefresh: 168
LogLevel: error
HistoryLimit: 10
HistoryMinutes: 1440
ProfileFormat: "{{ `{{ FirstItem .AccountName (.AccountAlias | nospace) }}` }}-{{ `{{ .RoleName }}` }}"
FullTextSearch: true
UrlAction: open-url-in-container
UrlExecCommand:
    - /Applications/Firefox.app/Contents/MacOS/firefox
    - "%s"
