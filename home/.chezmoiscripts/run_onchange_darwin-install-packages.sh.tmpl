{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

{{/* Collect taps from any owner/tap/formula entries so brew trust can allow them. */ -}}
{{- $taps := list -}}
{{- range .packages.darwin.brews -}}
{{-   $parts := splitList "/" . -}}
{{-   if eq (len $parts) 3 -}}
{{-     $taps = append $taps (printf "%s/%s" (index $parts 0) (index $parts 1)) -}}
{{-   end -}}
{{- end -}}
{{- $taps = $taps | uniq -}}
{{ range $taps -}}
brew trust --tap {{ . | quote }}
{{ end -}}

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ end -}}
