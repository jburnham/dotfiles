{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

{{/* Combine base brews with work-only brews when on a work machine. */ -}}
{{- $brews := .packages.darwin.brews -}}
{{- if .work_computer -}}
{{-   $brews = concat $brews .packages.darwin.work_brews -}}
{{- end -}}

{{/* Collect taps from any owner/tap/formula entries so they can be trusted and cloned before install. */ -}}
{{- $taps := list -}}
{{- range $brews -}}
{{-   $parts := splitList "/" . -}}
{{-   if eq (len $parts) 3 -}}
{{-     $taps = append $taps (printf "%s/%s" (index $parts 0) (index $parts 1)) -}}
{{-   end -}}
{{- end -}}
{{- $taps = $taps | uniq -}}
{{ range $taps -}}
brew trust --tap {{ . | quote }}
{{ end -}}

brew bundle --file=/dev/stdin <<EOF
{{ range $taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range $brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ end -}}
