{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "blue": "blue",
    "magenta": "magenta",
    "white": "white",
    "yellow": "yellow"
  },
  "accent_color": "32",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "style": "full"
          },
          "template": "{{ .Path }}",
          "foreground": "p:blue",
          "background": "transparent",
          "type": "path",
          "style": "plain"
        },
        {
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " on  {{if .UpstreamURL}}{{ url (printf \"<u>%s</u>\" .HEAD) .UpstreamURL }}{{else}}{{ .HEAD }}{{end}}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}",
          "foreground": "p:magenta",
          "background": "transparent",
          "type": "git",
          "style": "plain"
        },
        {
          "template": " 󰯉 {{ .Model.DisplayName }}  {{ .TokenUsagePercent.GaugeUsed }}",
          "foreground": "accent",
          "background": "transparent",
          "type": "claude",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "template": "{{if .RateLimits}}5h:{{ .FiveHourUsage }}% 7d:{{ .SevenDayUsage }}%{{end}}",
          "foreground": "accent",
          "background": "transparent",
          "type": "claude",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 4
}
