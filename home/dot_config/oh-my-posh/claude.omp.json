{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "blue": "blue",
    "magenta": "magenta",
    "white": "white",
    "yellow": "yellow",
    "red": "red"
  },
  "accent_color": "32",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "style": "full"
          },
          "template": "{{ .Path }}",
          "foreground": "p:blue",
          "background": "transparent",
          "type": "path",
          "style": "plain"
        },
        {
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " on  {{if .UpstreamURL}}{{ url (printf \"<u>%s</u>\" .HEAD) .UpstreamURL }}{{else}}{{ .HEAD }}{{end}}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}",
          "foreground": "p:magenta",
          "background": "transparent",
          "type": "git",
          "style": "plain"
        },
        {
          "template": " 󰯉 {{ .Model.DisplayName }}  {{ .TokenUsagePercent.GaugeUsed }} {{ if .ContextWindow.CurrentUsage }}{{ div (add .ContextWindow.CurrentUsage.InputTokens .ContextWindow.CurrentUsage.CacheCreationInputTokens .ContextWindow.CurrentUsage.CacheReadInputTokens) 1000 }}{{ else }}0{{ end }}/{{ div .ContextWindow.ContextWindowSize 1000 }}K",
          "foreground": "accent",
          "background": "transparent",
          "type": "claude",
          "style": "plain"
        },
        {
          "template": "{{if .RateLimits}} 󰎰 {{ .FiveHourGauge }}{{end}}",
          "foreground": "accent",
          "foreground_templates": [
            "{{if gt .FiveHourUsage 89}}p:red{{end}}",
            "{{if gt .FiveHourUsage 79}}p:yellow{{end}}"
          ],
          "background": "transparent",
          "type": "claude",
          "style": "plain"
        },
        {
          "template": "{{if .RateLimits}}{{if gt .SevenDayUsage 74}} 󰎸 {{ .SevenDayGauge }}{{end}}{{end}}",
          "foreground": "accent",
          "foreground_templates": [
            "{{if gt .SevenDayUsage 89}}p:red{{end}}",
            "{{if gt .SevenDayUsage 79}}p:yellow{{end}}"
          ],
          "background": "transparent",
          "type": "claude",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 4
}
