{{- $work := promptBoolOnce . "work_computer" "Is this a work computer" -}}
{{- $credTool := "" -}}
{{- $mcpHost := "" -}}
{{- $dropMcpHost := "" -}}
{{- $workEmail := "" -}}
{{- $workOrgs := "" -}}
{{- $workVault := "" -}}
{{- $privateTerms := promptStringOnce . "private_terms" "Private terms to block from commits, comma-separated" -}}
{{- if $work -}}
{{-   $credTool = promptStringOnce . "cred_tool" "Credential helper name (bare tool word)" -}}
{{-   $mcpHost = promptStringOnce . "work_mcp_host" "Work MCP host (e.g. mcp.example.com)" -}}
{{-   $dropMcpHost = promptStringOnce . "drop_mcp_host" "Drop MCP host (e.g. drop.example.com)" -}}
{{-   $workEmail = promptStringOnce . "work_email" "Work git email" -}}
{{-   $workOrgs = promptStringOnce . "work_orgs" "Work GitHub org slugs (comma-separated)" -}}
{{-   $workVault = promptStringOnce . "work_vault" "Work 1Password vault name (e.g. for SSH agent keys)" -}}
{{- end -}}

[data]
    work_computer = {{ $work }}
    cred_tool = {{ $credTool | quote }}
    work_mcp_host = {{ $mcpHost | quote }}
    drop_mcp_host = {{ $dropMcpHost | quote }}
    work_email = {{ $workEmail | quote }}
    work_orgs = {{ $workOrgs | quote }}
    work_vault = {{ $workVault | quote }}
    private_terms = {{ $privateTerms | quote }}

[diff]
{{- if lookPath "delta" }}
    pager = "delta"
{{- end }}
[[textconv]]
    pattern = "**/.claude/settings.json"
    command = "jq"
    args = ["--sort-keys", "."]
[[textconv]]
    pattern = "**/.claude/settings.local.json"
    command = "jq"
    args = ["--sort-keys", "."]
[merge]
    command = "nvim"
    args = [
        "-d",
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]
