{{- $work := promptBoolOnce . "work_computer" "Is this a work computer" -}}
{{- $credTool := "" -}}
{{- $mcpHost := "" -}}
{{- $workEmail := "" -}}
{{- $workOrgs := "" -}}
{{- if $work -}}
{{-   $credTool = promptStringOnce . "cred_tool" "Credential helper name (bare tool word)" -}}
{{-   $mcpHost = promptStringOnce . "work_mcp_host" "Work MCP host (e.g. mcp.example.com)" -}}
{{-   $workEmail = promptStringOnce . "work_email" "Work git email" -}}
{{-   $workOrgs = promptStringOnce . "work_orgs" "Work GitHub org slugs (comma-separated)" -}}
{{- end -}}

[data]
    work_computer = {{ $work }}
    cred_tool = {{ $credTool | quote }}
    work_mcp_host = {{ $mcpHost | quote }}
    work_email = {{ $workEmail | quote }}
    work_orgs = {{ $workOrgs | quote }}

[diff]
    pager = "delta"
[[textconv]]
    pattern = "**/.claude/settings.json"
    command = "jq"
    args = ["--sort-keys", "."]
[[textconv]]
    pattern = "**/.claude/settings.local.json"
    command = "jq"
    args = ["--sort-keys", "."]
[merge]
    command = "nvim"
    args = [
        "-d",
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]
