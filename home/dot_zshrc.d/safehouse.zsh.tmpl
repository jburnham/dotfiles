# Build a colon-separated dir list from candidates, keeping only those that
# exist. Avoids safehouse erroring out on dirs that are absent on this machine
# (e.g. ~/.aws-sso on a personal laptop).
_safehouse_existing_dirs() {
    local dir
    local -a found
    for dir in "$@"; do
        [[ -d $dir ]] && found+=("$dir")
    done
    local IFS=:
    print -r -- "${found[*]}"
}

export SAFEHOUSE_ADD_DIRS_RO="$(_safehouse_existing_dirs \
    "$HOME/.config/oh-my-posh" \
    "$HOME/.cloudflared" \
    "$HOME/.local/bin" \
    "$HOME/.cache/huggingface")"

export SAFEHOUSE_ADD_DIRS="$(_safehouse_existing_dirs \
    "$HOME/.memsearch" \
    "$HOME/.aws-sso" \
{{- if .cred_tool }}
    "$HOME/.local/state/{{ .cred_tool }}" \
{{- end }}
    "$HOME/.cdk" \
    "$HOME/.claude")"

# work around bug in opencode https://github.com/anomalyco/opencode/issues/33632
export OPENCODE_DISABLE_FFF=1
safe() {
    local resolved_home project_dir git_root
    resolved_home="$(cd "$HOME" && pwd -P)"
    project_dir="$(pwd -P)"
    git_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -n $git_root ]] && project_dir="$(cd "$git_root" && pwd -P)"

    if [[ $project_dir == "$resolved_home" ]]; then
        echo "error: refusing to run from \$HOME ($resolved_home)" >&2
        echo "cd into a project directory first." >&2
        return 1
    fi

    local -a append_profile_args
    local profile
    for profile in ${HOME}/.config/safehouse/profiles/*.sb(N); do
        append_profile_args+=(--append-profile="$profile")
    done

    safehouse \
        --workdir="$project_dir" \
        --enable=cloud-credentials,keychain,process-control,1password,playwright-chrome \
        "${append_profile_args[@]}" \
        "$@"
}

safe-claude() { safe claude --dangerously-skip-permissions "$@" }
safe-codex()  { safe codex "$@" }
safe-opencode() { safe --env-pass=OPENCODE_DISABLE_FFF opencode "$@" }
