{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
{{- if eq .chezmoi.username "USERNAME" }}
  "awsCredentialExport": "$(brew --prefix)/bin/bedrock-credential-CREDTOOL -login",
  "env": {
    "aaaANTHROPIC_MODEL": "us.anthropic.claude-opus-4-6-v1",
    "ANTHROPIC_MODEL": "us.anthropic.claude-opus-4-7",
    "AWS_REGION": "us-east-1",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "SHELL": "/bin/bash"
  },
{{- end }}
  "permissions": {
    "allow": [
      "Bash(/Applications/GitButler.app/Contents/MacOS/gitbutler-tauri status --json)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(but status:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(docker:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(gradle:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(kubectl:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mvn:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pnpm:*)",
      "Bash(podman:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(rustc:*)",
      "Bash(swift:*)",
      "Bash(uv:*)",
      "Bash(xcrun:*)",
      "Bash(yarn:*)",
      "Read"
    ],
    "deny": [
      "Bash(chmod:*)",
      "Bash(git commit:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/.aws/credentials)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.ssh/**)",
      "Read(**/secrets/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
{{- if eq .chezmoi.username "USERNAME" }}
  "model": "us.anthropic.claude-opus-4-7",
{{- end }}
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/audit-command.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "oh-my-posh claude --config ~/.config/oh-my-posh/claude.omp.json",
    "padding": 0
  },
  "enabledPlugins": {
{{- if eq .chezmoi.username "USERNAME" }}
    "gopls-lsp@claude-plugins-official": true,
{{- end }}
    "superpowers@claude-plugins-official": true
  },
{{- if eq .chezmoi.username "USERNAME" }}
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "dddmodel": "opus",
{{- end }}
  "feedbackSurveyState": {
    "lastShownTime": 9999999999999
  }
}
