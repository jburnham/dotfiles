#!/usr/bin/env bash
set -euo pipefail

for cmd in jq chezmoi; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "modify_settings.json: $cmd is required but not found on PATH" >&2
    exit 1
  fi
done

# Per-user signal sourced from chezmoi data (`work_computer` in chezmoi.toml).
is_work=$(chezmoi execute-template '{{ .work_computer }}')
case "$is_work" in
  true | false) ;;
  *)
    echo "modify_settings.json: is_work template must return 'true' or 'false', got '$is_work'" >&2
    exit 1
    ;;
esac

# Credential helper name (bare tool word), sourced from chezmoi data
# (`cred_tool`). Empty on non-work machines; only used inside the $is_work
# branch below, so an empty value is harmless.
cred_tool=$(chezmoi execute-template '{{ .cred_tool }}')

# jq produces silent empty output on empty or whitespace-only stdin (no JSON
# value to parse), which would then be written to the target file. Guard here
# so the single jq call below always sees a valid JSON value on stdin.
# Malformed JSON, arrays, and scalars are caught by the normalization stage
# inside the jq program itself.
existing=$(cat)
[[ -z ${existing//[[:space:]]/} ]] && existing='{}'

printf '%s' "$existing" | jq --sort-keys --argjson is_work "$is_work" --arg cred_tool "$cred_tool" '
    # Normalize input: null from the shell-side guard becomes {};
    # objects pass through; arrays/scalars are rejected loudly.
    (if . == null then {}
     elif type == "object" then .
     else error("settings.json root must be a JSON object, got \(type)")
     end)
  | .["$schema"] = "https://json.schemastore.org/claude-code-settings.json"
  | .attribution = {
      commit: "",
      pr: ""
  }
  | .permissions.allow = [
      "Bash(/Applications/GitButler.app/Contents/MacOS/gitbutler-tauri status --json)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(but status:*)",
      "Bash(cargo:*)",
      "Bash(cat:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(gradle:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(kubectl:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mvn:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pnpm:*)",
      "Bash(podman:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(rustc:*)",
      "Bash(swift:*)",
      "Bash(tee:*)",
      "Bash(uv:*)",
      "Bash(xcrun:*)",
      "Bash(yarn:*)",
      "Read"
    ]
  | .permissions.deny = [
      "Bash(sudo:*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/.aws/credentials)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.ssh/**)",
      "Read(**/secrets/**)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  | .hooks.PreToolUse = [
      {
        matcher: "Bash",
        hooks: [
          {
            type: "command",
            command: "$HOME/.claude/hooks/audit-command.sh",
            timeout: 10
          }
        ]
      }
    ]
  | .statusLine = {
      type: "command",
      command: "oh-my-posh claude --config ~/.config/oh-my-posh/claude.omp.json",
      padding: 0
    }
  | .alwaysThinkingEnabled = true
  | .skipDangerousModePermissionPrompt = true
  | .dddmodel             = "opus"
  | .enabledPlugins       = {
      "superpowers@claude-plugins-official": true,
      "superpowers-chrome@superpowers-marketplace": true
    }
  | .env                       = { SHELL: "/bin/bash" }
  | .extraKnownMarketplaces    = {
      "superpowers-marketplace": {
        source: {
          source: "github",
          repo: "obra/superpowers-marketplace"
        }
      }
    }
  | if $is_work then
        .enabledPlugins         += {
          "gopls-lsp@claude-plugins-official": true,
          "memsearch@memsearch-plugins": true
        }
      | .extraKnownMarketplaces += {
          "memsearch-plugins": {
            source: {
              source: "github",
              repo: "zilliztech/memsearch"
            }
          }
        }
      | .env                    += {
          aaaANTHROPIC_MODEL: "us.anthropic.claude-opus-4-6-v1",
          bbbANTHROPIC_MODEL: "us.anthropic.claude-opus-4-7",
          ANTHROPIC_DEFAULT_SONNET_MODEL: "us.anthropic.claude-sonnet-4-6",
          AWS_REGION: "us-east-1",
          CLAUDE_CODE_USE_BEDROCK: "1"
        }
      | .awsCredentialExport     = "$(brew --prefix)/bin/bedrock-credential-\($cred_tool) -login"
    else
        .enabledPlugins         += {
          "codex@openai-codex": true
        }
      | .extraKnownMarketplaces += {
          "openai-codex": {
            source: {
              source: "github",
              repo: "openai/codex-plugin-cc"
            }
          }
        }
    end
'
